// fibonacci.mylang — recursive function, prints first 10 Fibonacci numbers

fn fibonacci(n) {
    if n <= 0 { return 0; }
    if n == 1 { return 1; }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

print("first 10 fibonacci numbers:");

let i = 1;
while i <= 10 {
    print(fibonacci(i));
    let i = i + 1;
}
