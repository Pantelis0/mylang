// hello.mylang — variables, arithmetic, strings, print

let name = "mylang";
print("welcome to " + name);

let x = 10;
let y = 3;

print("arithmetic:");
print(x + y);
print(x - y);
print(x * y);
print(x / y);

print("comparisons:");
if x > y {
    print("x is greater than y");
} else {
    print("y is greater than x");
}

if x == 10 {
    print("x is ten");
}
